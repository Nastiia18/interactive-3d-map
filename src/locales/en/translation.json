    "descriptions": {
      "rector": "<p><strong>Rector's Office</strong> — the working space of the head of NaUOA, Professor Ihor Pasichnyk. The hub of strategic university management, hosting official receptions for diplomats, ambassadors, and honored guests.</p>",
      "academiccouncil": "<p><strong>Academic Council Chamber</strong> — the venue for meetings of the university's governing body. This space is used to approve NaUOA development strategies, educational programs, and host thesis defenses.</p>",
      "prorector": "<p><strong>Vice-Rector for Student Affairs Office</strong> — the center for coordinating extracurricular university life. It manages student self-governance, dormitories, cultural, and volunteer projects.</p>",
      "assistantrector": "<p><strong>Assistant to the Rector's Office</strong> — the organizational wing of the management. Coordinates the Rector's schedule, official visits, and communication with university partners.</p>",
      "rectorsroom": "<p><strong>Rector's Reception Room</strong> — the central hall of the administrative block. It serves as a collection hub for official inquiries from faculty and students, and a waiting area for delegations.</p>",
      "ViceRectorResearch": "<p><strong>Vice-Rector for Research Office</strong> — the headquarters of scientific activity at NaUOA. Manages postgraduate studies, research publications, and international conferences.</p>",
      "dekan_economic": "<p><strong>Dean's Office</strong> — the official office of the head of the Faculty of Economics. Designed for strategic planning, student hours, and resolving academic matters.</p>",
      "dekanat_economic": "<p><strong>Faculty Office</strong> — the administrative center of the faculty. Here, registration officers and deputy deans manage schedules, exams, and issue certificates to students.</p>"
    },
